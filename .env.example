# PostgreSQL (database, watchdog)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mqtt_watchdog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root123

# MQTT broker (simulator, watchdog)
MQTT_HOST=mosquitto
MQTT_PORT=1883

# Redis (heartbeat store, watchdog)
REDIS_HOST=redis
REDIS_PORT=6379

# Watchdog timing (seconds)
HEARTBEAT_INTERVAL=30
WATCHDOG_CHECK_INTERVAL=10
HEARTBEAT_TIMEOUT=90

# Simulator
SIMULATOR_DEVICE_COUNT=10
SIMULATOR_FREEZE_PROBABILITY=0.02
